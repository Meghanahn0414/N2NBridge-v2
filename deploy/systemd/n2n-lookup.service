[Unit]
Description=N2N Lookup Service (FastAPI)
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/n2n-lookup/current
ExecStart=/var/www/n2n-lookup/current/venv/bin/uvicorn main:app --host 0.0.0.0 --port 9001
Restart=on-failure
RestartSec=3
# Reads /var/www/n2n-lookup/current/.env, which is itself a symlink to
# /var/www/n2n-lookup/shared/.env — see deploy-lookup.sh.

[Install]
WantedBy=multi-user.target
