# ============================================================
# CRM Backend — Production Environment Variables
# Copy this file to .env on your EC2 server and fill in real values
# DO NOT commit the actual .env file to git
# ============================================================

# --- MongoDB (use your Atlas connection string) ---
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/crm_database?retryWrites=true&w=majority
MONGODB_DB=crm_database

# --- JWT Security (MUST change — use a long random string) ---
# Generate one: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_A_64_CHAR_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=False

# --- CORS: your EC2 public IP or domain ---
FRONTEND_ORIGIN=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN
CORS_ALLOW_REGEX=

# --- Redis (install Redis on EC2: sudo apt install redis-server) ---
# All three can point to the same Redis instance with different DB numbers
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AWS S3 (file uploads — replaces local /uploads folder) ---
# Create an S3 bucket and IAM user with s3:PutObject + s3:DeleteObject permissions
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-crm-uploads-bucket
# Setting S3_BUCKET_NAME automatically enables S3 storage (USE_S3_STORAGE=True)

# --- Email (optional — for OTP emails) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com

# --- SMS / Twilio (optional — for OTP SMS) ---
SMS_API_KEY=your_twilio_auth_token
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
