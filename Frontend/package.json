{
  "name": "crm-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"vite --open\" \"npm run dev:web --prefix ../MobileApp\"",
    "build": "vite build",
    "build:all": "vite build && cd ../MobileApp && npx expo export --platform web && xcopy /E /I /Y dist ..\\Frontend\\dist\\citizen",
    "start": "vite --host"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "xlsx": "^0.18.5",
    "i18next": "^26.3.1",
    "jspdf": "^2.5.1",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.17.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.1.0"
  }
}
