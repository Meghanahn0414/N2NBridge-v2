# Lookup Service — the one fixed, always-reachable place the mobile app
# and every representative's server ask "who handles Ward X / Assembly Y /
# Parliamentary Z, and what is their server's URL?"
#
# This service holds NO citizen or grievance data — only the routing
# registry (which representative maps to which server_url). Deploy this
# once, centrally, and keep its URL stable — every mobile app build and
# every representative server points at it.

# Its own dedicated MongoDB (separate from any representative's DB)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=n2n_lookup

# Shared secret a representative's server must send to register/update
# itself in the lookup service. Set this to a long random value and give the
# same value to every representative server's LOOKUP_REGISTER_KEY.
LOOKUP_REGISTER_KEY=change-this-shared-secret

HOST=0.0.0.0
PORT=9000
DEBUG=False

# Comma-separated list, or * for any (tighten this in production)
CORS_ORIGINS=*
