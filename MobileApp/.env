# ─── Dev: Expo web runs behind Vite proxy ─────────────────────────────────────
# When using `npm run dev` from the root, the citizen app is at:
#   http://localhost:3000/citizen/
# Vite proxies /api → localhost:8000, so leave EXPO_PUBLIC_API_URL empty
# for web mode (relative URLs work automatically through the proxy).
#
# EXPO_PUBLIC_API_URL=   ← leave blank for web mode

# ─── Physical device (Android/iOS via Expo Go) ────────────────────────────────
# Uncomment and set your PC's LAN IP so the phone can reach your local backend.
# Find it: open Command Prompt → run `ipconfig` → look for IPv4 Address (Wi-Fi)
#
# EXPO_PUBLIC_API_URL=http://192.168.1.34:8000

# Lookup Service — the ONE fixed, permanent address the citizen app needs.
# Every representative's own server is resolved dynamically at runtime through
# this, so this is the only URL that needs to be "production-correct."
#
# NOTE: these EXPO_PUBLIC_* values are baked into the JS bundle at BUILD time,
# not read from this file at runtime on the user's phone. For the actual
# Play Store build, `eas.json`'s "production" profile now sets
# EXPO_PUBLIC_LOOKUP_URL=https://kvslookup.in directly and takes precedence
# over whatever is in this file — this line below is just so local runs
# (`expo start`, `expo start --tunnel`) also hit production instead of LAN.
EXPO_PUBLIC_LOOKUP_URL=https://kvslookup.in


