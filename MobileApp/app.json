{
  "expo": {
    "name": "N2N",
    "slug": "n2n",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/n2n-logo-icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/n2n-logo-icon.png",
        "backgroundColor": "#0f1629"
      },
      "package": "com.fatima237.mobileapp"
    },
    "web": {
      "output": "single",
      "favicon": "./src/assets/images/n2n-logo-icon.png",
      "bundler": "metro",
      "baseUrl": "/citizen"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f1629",
          "android": {
            "image": "./src/assets/images/n2n-logo-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a89c23eb-1bda-4a7d-a2a7-88a23a405164"
      }
    },
    "owner": "fatima237"
  }
}
